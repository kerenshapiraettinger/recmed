# Copy this file to .env and fill in your API keys

# TMDB (The Movie Database) — free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_key_here

# OMDb — free (1000 req/day) at https://www.omdbapi.com/apikey.aspx
# Optional — only used for plot text on title detail pages
OMDB_API_KEY=your_omdb_key_here

# Flask session encryption key — change to any random string
SECRET_KEY=change-me-please

# Admin panel password (used as ?secret= query param)
ADMIN_SECRET=admin123
